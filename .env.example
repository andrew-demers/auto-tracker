# Copy this file to .env and fill in real values for your deployment.

# --- Database -----------------------------------------------------------
# SQLite file path. Default in Docker is file:/data/auto-tracker.db,
# default for local dev is file:./dev.db
DATABASE_URL="file:./dev.db"

# --- Auth (Auth.js / next-auth) -----------------------------------------
# Secret used to sign/encrypt session JWTs. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=""

# --- First-run admin seed ------------------------------------------------
# Used by prisma/seed.ts to create the first ADMIN user if no users exist.
# If unset, defaults to admin@localhost with a randomly generated password
# (printed to the console on first seed run).
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# --- File storage ---------------------------------------------------------
# Directory where uploaded attachments (receipts, etc.) are stored.
UPLOADS_DIR="/data/uploads"

# --- Email notifications (SMTP via nodemailer) ----------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
# Master on/off switch for the daily maintenance-reminder email job.
NOTIFICATIONS_ENABLED="false"

# --- App URL ---------------------------------------------------------------
# Used to build absolute links in emails and the Google OAuth redirect URI.
APP_URL="http://localhost:3000"

# --- Google Drive backup (OAuth2) ------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Number of most-recent backup archives to retain in Drive.
BACKUP_RETENTION_COUNT="14"

# --- Docker only: PUID/PGID ------------------------------------------------
# User/group id the container runs as after fixing up /data ownership.
# Defaults match Unraid's nobody:users - see the README's Unraid section.
PUID="99"
PGID="100"
